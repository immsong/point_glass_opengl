#version 300 es

// ============================================================================
// gizmos.frag
// ============================================================================
//
// grid, axis, polygonмқҳ мөңмў… мғүмғҒмқ„ м¶ңл Ҙн•ҳлҠ” fragment shader.
//
// points.fragмҷҖ лӢ¬лҰ¬ м»¬лҹ¬л§ө кі„мӮ°мқҙ м—ҶмқҢ.
// Vertex Shaderм—җм„ң л„ҳм–ҙмҳЁ vColorлҘј к·ёлҢҖлЎң FragColorлЎң м¶ңл Ҙн•Ё.

// OpenGL ESм—җм„ңлҠ” fragment shaderмқҳ float м •л°ҖлҸ„ м§Җм • н•„мҡ”.
precision mediump float;

// ============================================================================
// [INPUT]
// ============================================================================
//
// gizmos.vertм—җм„ң:
//
// out vec4 vColor;
//
// лЎң л„ҳкёҙ мғүмғҒ.
//
// vec4 = RGBA.
in vec4 vColor;

// ============================================================================
// [OUTPUT]
// ============================================================================
//
// мөңмў… pixel/fragment мғүмғҒ.
out vec4 FragColor;

// ============================================================================
// [MAIN]
// ============================================================================
void main() {
    // лі„лҸ„ кі„мӮ° м—Ҷмқҙ мһ…л Ҙ мғүмғҒ к·ёлҢҖлЎң м¶ңл Ҙ.
    //
    // мҳҲ:
    // vColor = vec4(1.0, 0.0, 0.0, 1.0)
    // кІ°кіј = л№Ёк°„мғү л¶ҲнҲ¬лӘ…
    FragColor = vColor;
}