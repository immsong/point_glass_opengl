#version 300 es

// ============================================================================
// gizmos.vert
// ============================================================================
//
// 이 파일은 grid, axis, polygon 같은 보조 도형의 위치를 계산하는 shader.
//
// points.vert와 비슷하지만 차이가 있음.
//
// points.vert:
// - 입력: position + value
// - value를 fragment shader로 넘겨서 색상 계산
//
// gizmos.vert:
// - 입력: position + color
// - 이미 완성된 color를 그대로 fragment shader로 넘김
//
// 즉 grid/axis는 point cloud처럼 컬러맵 계산이 필요 없음.
// Dart/Rust 쪽에서 정한 색상을 그대로 사용함.

// ============================================================================
// [INPUT] Rust VBO에서 넘어오는 데이터
// ============================================================================
//
// 데이터 포맷:
//
// [x, y, z, r, g, b, a, pad, ...]
//
// float 8개가 하나의 vertex.
//
// x, y, z : 3D 좌표
// r, g, b, a : 색상
// pad : 현재 shader에서는 사용하지 않는 여분 값
//       예전 구조에서 thickness 등을 넣기 위해 남겼을 수 있음.

// location = 0
//
// 3D position.
// Rust 쪽 VertexAttribPointer(0, 3, ...)와 연결됨.
layout(location = 0) in vec3 aPos;

// location = 1
//
// 완성된 RGBA 색상.
// Rust 쪽 VertexAttribPointer(1, 4, ...)와 연결됨.
layout(location = 1) in vec4 aColor;

// ============================================================================
// [UNIFORM]
// ============================================================================
//
// point shader와 동일하게 3D 좌표를 화면 좌표로 변환하는 MVP matrix.
uniform mat4 uMVP;

// ============================================================================
// [OUTPUT]
// ============================================================================
//
// Fragment Shader로 넘길 색상.
// 여기서는 별도 계산 없이 aColor를 그대로 넘김.
out vec4 vColor;

// ============================================================================
// [MAIN]
// ============================================================================
void main() {
    // 3D position을 clip space로 변환.
    //
    // 이 값이 화면에서 line/polygon vertex가 표시될 위치를 결정.
    gl_Position = uMVP * vec4(aPos, 1.0f);

    // 색상을 fragment shader로 전달.
    //
    // line이나 triangle 내부 fragment들은 이 색상을 보간해서 받음.
    // 같은 색상의 vertex들로 만든 선/면이면 결과도 동일한 색상으로 보임.
    vColor = aColor;
}