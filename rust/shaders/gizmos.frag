#version 300 es // 1. 사용할 OpenGL 버전을 선언합니다.

// 소수점 계산 정밀도를 설정합니다. (모바일/웹 표준)
precision mediump float;

// ============================================================================
// [INPUT & OUTPUT] 
// ============================================================================
// in: 스케치 화가(Vertex Shader)가 던져준 색상 택배 상자입니다.
in vec4 vColor;

// out: 모니터의 픽셀에 최종적으로 쏴줄 색상입니다.
out vec4 FragColor;


// ============================================================================
// [MAIN]
// ============================================================================
void main() {
    // 아무런 수학 계산(Turbo, Rainbow)도 하지 않습니다!
    // 스케치 화가가 넘겨준 색상(vColor)을 그대로 픽셀 색상(FragColor)으로 칠합니다.
    // (예: Dart에서 (1.0, 0.0, 0.0, 1.0)을 보냈다면 그대로 새빨간 색으로 칠함)
    FragColor = vColor;
}