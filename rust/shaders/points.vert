#version 300 es // 1. 사용할 OpenGL 버전을 선언합니다. 
// "300 es"는 WebGL 2.0 및 모바일(OpenGL ES 3.0)에서 돌아가는 최신 표준을 의미합니다.

// ============================================================================
// [INPUT] Rust(CPU)에서 배열로 넘겨주는 데이터들 (in)
// ============================================================================
// location = 0: Rust의 VertexAttribPointer에서 0번으로 뚫어놓은 파이프입니다.
// vec3(숫자 3개짜리 묶음) 형태로 X, Y, Z 좌표를 받습니다.
layout(location = 0) in vec3 aPos;

// location = 1: Rust에서 1번으로 뚫어놓은 파이프입니다.
// float(숫자 1개) 형태로 센서의 값(Z축 높이, 반사 강도 등)을 받습니다.
layout(location = 1) in float aValue;

// ============================================================================
// [UNIFORM] 전체 도화지에 일괄적으로 적용되는 설정값들 (uniform)
// ============================================================================
// uMVP: 카메라 매트릭스 (Model-View-Projection)
// 3D 공간에 있는 점을 2D 모니터 화면으로 투영시키기 위한 마법의 수학 공식입니다.
uniform mat4 uMVP;

// uPointSize: 다트(Dart) UI의 슬라이더에서 받아온 전체 점의 크기입니다.
uniform float uPointSize;

// ============================================================================
// [OUTPUT] 다음 화가(Fragment Shader)에게 넘겨줄 데이터 (out)
// ============================================================================
// 위치와 크기는 버텍스 셰이더가 직접 쓰지만, '색상'은 다음 화가가 칠해야 합니다.
// 그래서 내가 받은 값(aValue)을 다음 화가에게 전달하기 위해 내보낼 준비를 합니다.
out float vValue;

// ============================================================================
// [MAIN] 10만 개의 점이 들어올 때마다 10만 번 실행되는 메인 함수
// ============================================================================
void main() {
    // 1. 점의 최종 화면 위치 계산 (가장 중요!)
    // 카메라 공식(uMVP)에 내 원래 3D 위치(aPos)를 곱해서, 모니터 화면의 어디에 찍힐지 계산합니다.
    // gl_Position은 OpenGL이 기본으로 제공하는 예약어(내장 변수)입니다.
    gl_Position = uMVP * vec4(aPos, 1.0f);

    // 2. 점의 크기 결정
    // gl_PointSize 역시 예약어입니다. 외부에서 받아온 점 크기(uPointSize)를 그대로 적용합니다.
    gl_PointSize = uPointSize;

    // 3. 다음 화가(Fragment Shader)에게 바통 터치
    // "야! 이 점의 값은 aValue야! 이따가 네가 이거 보고 색깔 칠해!" 하고 넘겨줍니다.
    vValue = aValue;
}